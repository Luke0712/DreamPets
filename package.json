{
  "name": "qq-desktop-pet",
  "version": "0.1.0",
  "private": true,
  "description": "A tiny transparent desktop pet powered by Electron.",
  "main": "src/main.js",
  "scripts": {
    "start": "npm run build:settings && electron .",
    "pack": "npm run build:settings && electron-builder --mac dir",
    "dist": "npm run build:settings && electron-builder --mac",
    "build:settings": "vite build src/renderer/settings-app --config src/renderer/settings-app/vite.config.js"
  },
  "build": {
    "appId": "com.luke.qq-desktop-pet",
    "productName": "桌面宠物",
    "files": [
      "src/**/*",
      "assets/**/*",
      "build/icon.icns",
      "build/tray-icon.png",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns",
      "target": [
        "dir",
        "dmg"
      ],
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "directories": {
      "output": "dist"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^31.7.7",
    "electron-builder": "^26.15.3",
    "vite": "^8.1.3"
  },
  "dependencies": {
    "@ant-design/icons": "^6.3.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "antd": "^6.5.0",
    "node-pty": "^1.1.0",
    "pngjs": "^7.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
